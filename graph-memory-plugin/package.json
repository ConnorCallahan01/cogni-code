{
  "name": "cogni-code",
  "version": "3.4.4",
  "type": "module",
  "description": "Persistent, self-evolving memory for AI agents. Gives Claude Code, Codex CLI, OpenCode, and pi a knowledge graph that grows from conversations.",
  "license": "MIT",
  "author": "Connor Callahan",
  "homepage": "https://cognicode.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/ConnorCallahan01/cogni-code.git",
    "directory": "graph-memory-plugin"
  },
  "bugs": {
    "url": "https://github.com/ConnorCallahan01/cogni-code/issues"
  },
  "keywords": [
    "ai-memory",
    "knowledge-graph",
    "mcp",
    "claude-code",
    "codex",
    "opencode",
    "agent-memory",
    "persistent-memory",
    "context-management"
  ],
  "main": "dist/graph-memory/mcp-server.js",
  "bin": {
    "cogni-code": "dist/graph-memory/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && npm run copy-prompts",
    "copy-prompts": "rm -rf dist/graph-memory/prompts && cp -R src/graph-memory/prompts dist/graph-memory/prompts",
    "dev": "tsc --watch",
    "mcp": "node dist/graph-memory/mcp-server.js",
    "prepare": "npm run build",
    "prepublishOnly": "node --test tests/*.check.mjs",
    "status": "node -e \"import('./dist/graph-memory/tools.js').then(m => m.handleGraphMemory({action:'status'}).then(r => console.log(r.content[0].text)))\"",
    "test": "npm run build && node --test tests/*.check.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "simple-git": "^3.36.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.37",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist/",
    "bin/",
    "docker/",
    "commands/",
    "agents/",
    "skills/",
    "hooks/",
    ".claude-plugin/",
    "extensions/",
    "opencode-commands/",
    "templates/",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/graph-memory.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./templates"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  }
}
