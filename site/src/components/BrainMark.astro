---
interface Props {
	class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg class={`brain-mark ${className}`} viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <g class="bm-edges" stroke="currentColor" stroke-width="6" stroke-linecap="round" stroke-linejoin="round">
    <path d="M40 130L60 90" />
    <path d="M60 90L100 74" />
    <path d="M100 74L140 74" />
    <path d="M140 74L176 94" />
    <path d="M176 94L184 130" />
    <path d="M184 130L164 154" />
    <path d="M164 154L140 146" />
    <path d="M140 146L120 168" />
    <path d="M120 168L116 198" />
    <path d="M140 146L100 130" />
    <path d="M100 130L100 74" />
    <path d="M100 130L60 90" />
    <path d="M100 130L40 130" />
    <path d="M140 146L176 94" />
    <path d="M140 146L184 130" />
  </g>
  <g class="bm-nodes" stroke="currentColor" stroke-width="6">
    <circle cx="100" cy="74" r="11" />
    <circle cx="184" cy="130" r="11" />
    <circle cx="116" cy="198" r="11" />
    <circle cx="40" cy="130" r="11" />
    <circle cx="60" cy="90" r="11" />
    <circle cx="140" cy="74" r="11" />
    <circle cx="176" cy="94" r="11" />
    <circle cx="164" cy="154" r="11" />
    <circle cx="120" cy="168" r="11" />
    <circle cx="100" cy="130" r="11" />
  </g>
  <circle class="bm-accent" cx="100" cy="74" r="11" stroke="none" />
  <circle class="bm-accent" cx="184" cy="130" r="11" stroke="none" />
  <circle class="bm-accent" cx="116" cy="198" r="11" stroke="none" />
</svg>

<style>
  .brain-mark {
		color: inherit;
		display: block;
	}
  .brain-mark .bm-nodes { fill: var(--cream); }
  .brain-mark .bm-accent { fill: var(--slate); }
</style>
